#---------------------------------------------------------------------------------
# MicroPython for Game Boy Advance (ARM7TDMI)
#---------------------------------------------------------------------------------

.SUFFIXES:

#---------------------------------------------------------------------------------
# Require devkitARM
#---------------------------------------------------------------------------------
ifeq ($(strip $(DEVKITARM)),)
$(error "Please set DEVKITARM in your environment. export DEVKITARM=<path to devkitARM>")
endif

#---------------------------------------------------------------------------------
# MicroPython root
#---------------------------------------------------------------------------------
TOP := ../..

include $(TOP)/py/mkenv.mk
include $(TOP)/py/py.mk

include $(DEVKITARM)/gba_rules

#---------------------------------------------------------------------------------
# Output configuration
#---------------------------------------------------------------------------------
TARGET		:=	micropython_gba
BUILD		:=	build

#---------------------------------------------------------------------------------
# Toolchain
#---------------------------------------------------------------------------------
CROSS_COMPILE	:=	arm-none-eabi-

export PATH := $(DEVKITARM)/bin:$(PATH)

#---------------------------------------------------------------------------------
# CPU architecture
#
# GBA uses:
#   ARM7TDMI
#   ARMv4T
#   no hardware floating point
#---------------------------------------------------------------------------------
ARCH	:=	-mthumb -mthumb-interwork

CFLAGS += \
	-g \
	-Wall \
	-std=gnu99 \
	-Os \
	-DNDEBUG \
	-mcpu=arm7tdmi \
	-mtune=arm7tdmi \
	-mthumb \
	-fomit-frame-pointer \
	-ffunction-sections \
	-fdata-sections \
	-fno-builtin \
	$(ARCH)

#---------------------------------------------------------------------------------
# Include paths
#---------------------------------------------------------------------------------
CFLAGS += \
	-I. \
	-I$(TOP) \
	-I$(BUILD)

#---------------------------------------------------------------------------------
# Linker flags
#---------------------------------------------------------------------------------
LDFLAGS += \
	-specs=gba.specs \
	-g \
	-Wl,-Map,$(TARGET).map \
	-Wl,--gc-sections

#---------------------------------------------------------------------------------
# Optional MicroPython features
#---------------------------------------------------------------------------------
MICROPY_ROM_TEXT_COMPRESSION ?= 0

#---------------------------------------------------------------------------------
# Source files
#
# Add/remove files depending on how much of MicroPython
# you want running on the GBA.
#---------------------------------------------------------------------------------
SRC_C += \
	main.c \
	mphalport.c
#	gba_hal.c \
#	system_gba.c

# Core MicroPython objects
OBJ += $(PY_CORE_O)

# Project objects
OBJ += $(addprefix $(BUILD)/,$(SRC_C:.c=.o))

#---------------------------------------------------------------------------------
# Libraries
#---------------------------------------------------------------------------------
LIBS := -lgba -lm

LIBDIRS := $(LIBGBA)

LIBPATHS := $(foreach dir,$(LIBDIRS),-L$(dir)/lib)

INCLUDE := \
	$(foreach dir,$(LIBDIRS),-I$(dir)/include)

CFLAGS += $(INCLUDE)
LDFLAGS += $(LIBPATHS) $(LIBS)

#---------------------------------------------------------------------------------
# Targets
#---------------------------------------------------------------------------------
.PHONY: all clean

all: $(BUILD) $(TARGET).gba

#---------------------------------------------------------------------------------
# Build directory
#---------------------------------------------------------------------------------
$(BUILD):
	@mkdir -p $(BUILD)

#---------------------------------------------------------------------------------
# ELF
#---------------------------------------------------------------------------------

#$(TARGET).elf: $(OBJ)
#	@echo "LINK $@"
#	$(Q)$(LD) $(LDFLAGS) -o $@ $^
#	$(Q)$(SIZE) $@

$(TARGET).elf: $(OBJ)
	@echo "LINK $@"
	$(Q)$(CC) $(CFLAGS) -o $@ $^ $(LDFLAGS)
	$(Q)$(SIZE) $@


#---------------------------------------------------------------------------------
# GBA ROM
#---------------------------------------------------------------------------------
$(TARGET).gba: $(TARGET).elf
	@echo "OBJCOPY $@"
	$(Q)$(OBJCOPY) -O binary $< $@
	@gbafix $@

#---------------------------------------------------------------------------------
# Compile C
#---------------------------------------------------------------------------------
$(BUILD)/%.o: %.c
	@echo "CC $<"
	$(Q)$(CC) $(CFLAGS) -MMD -MP -c $< -o $@

#---------------------------------------------------------------------------------
# Dependencies
#---------------------------------------------------------------------------------
DEPENDS := $(OBJ:.o=.d)

-include $(DEPENDS)

#---------------------------------------------------------------------------------
# Include remaining MicroPython make rules
#---------------------------------------------------------------------------------
include $(TOP)/py/mkrules.mk

#---------------------------------------------------------------------------------
# Clean
#---------------------------------------------------------------------------------
clean:
	@echo "clean ..."
	@rm -rf $(BUILD)
	@rm -f $(TARGET).elf
	@rm -f $(TARGET).gba
	@rm -f $(TARGET).map


